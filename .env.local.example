# Copy to .env.local (never commit .env.local)

# Frontend → Convex backend URL
#   local dev:      http://127.0.0.1:3210
#   production:     https://convex.your-domain.com (self-hosted instance)
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Convex CLI → self-hosted deployment (see deploy/README steps)
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=paste_key_from_generate_admin_key.sh
