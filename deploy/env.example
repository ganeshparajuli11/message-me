# Copy to `.env` next to docker-compose.yml on the VPS and fill in.

# Public origins (behind your TLS reverse proxy, e.g. Caddy/nginx)
CONVEX_CLOUD_ORIGIN=https://convex.your-domain.com
CONVEX_SITE_ORIGIN=https://convex-site.your-domain.com

# Ports (defaults shown)
PORT=3210
SITE_PROXY_PORT=3211
DASHBOARD_PORT=6791

# Identity of this instance — set a random long secret and keep it safe.
INSTANCE_NAME=inkwell-prod
INSTANCE_SECRET=CHANGE_ME_64_hex_chars

# Dashboard target
NEXT_PUBLIC_DEPLOYMENT_URL=https://convex.your-domain.com
